# ============================================
# DeepDetect AI - Server Configuration
# ============================================

# Google Gemini API Key (Optional but Recommended)
# Get it from: https://aistudio.google.com/app/apikeys
# Leave as THIS VALUE to use simulation mode
GEMINI_API_KEY="AIzaSyA7OpQZsWXqJslZ04IwFuijFBsRQO2bW_U"

# Server Port
PORT=5002

# Google Cloud Vision Credentials (Optional)
# Path to your Google Cloud credentials JSON file
# Only needed if using Python web forensics service
GOOGLE_APPLICATION_CREDENTIALS="deepdetect-vision-credentials.json"

# Node Environment
NODE_ENV="development"

# CORS Configuration (comma-separated origins)
# Example: "http://localhost:5173,http://localhost:3000,https://example.com"
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"
